# ---------------------------------------------------------------------------
# rootmail — local environment
# Copy to .env (the seed/verify steps do this for you) and adjust as needed.
# ---------------------------------------------------------------------------

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://rootmail:rootmail@localhost:5432/rootmail

# Redis — queue, idempotency cache, rate limits (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# API server
API_PORT=4000
API_HOST=0.0.0.0
LOG_LEVEL=info

# Public base URL of the API — used in DNS instructions and unsubscribe links
PUBLIC_API_URL=http://localhost:4000

# Shared secret the first-party dashboard uses to call internal API endpoints
# (social-login user upsert). Set the SAME value in apps/dashboard/.env.local.
# Leave unset to disable social login. Generate with: openssl rand -hex 32
# INTERNAL_API_SECRET=

# --- Social login (OAuth) -------------------------------------------------
# These are read by the DASHBOARD — put them in apps/dashboard/.env.local:
#   INTERNAL_API_SECRET=<same as above>
#   DASHBOARD_URL=http://localhost:3001          # used to build OAuth redirect URIs
#   GOOGLE_CLIENT_ID= / GOOGLE_CLIENT_SECRET=
#   GITHUB_CLIENT_ID= / GITHUB_CLIENT_SECRET=
# Register the callback URL `${DASHBOARD_URL}/oauth/<provider>/callback` with
# each provider. Buttons appear automatically once a provider is configured.

# Root sending identity
ROOTMAIL_DOMAIN=rootmail.io
DKIM_SELECTOR=rootmail

# Sub-tenant domain verification:
#   mock = always pass (local dev, no real DNS)
#   live = perform real DNS TXT lookups for ownership + DKIM
DNS_VERIFY_MODE=mock

# Outbound provider: mock | sendgrid (sendgrid is a stub for now)
MAIL_PROVIDER=mock

# Where the mock provider writes rendered .eml files for inspection
MAILDIR=.maildir

# --- Billing (Stripe) -----------------------------------------------------
# Leave STRIPE_SECRET_KEY unset for "local" mode: plan changes apply instantly
# (the pre-Stripe self-serve switch) and prices come from the PLANS/ADD_ONS
# defaults baked into packages/core. Set it to switch on real Stripe Checkout.
# Create the products/prices in Stripe (test mode), then paste the price IDs
# here. Any price that's missing falls back to its default constant, so the app
# keeps working even mid-setup.
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...        # from `stripe listen --forward-to localhost:4000/v1/webhooks/stripe`
#   STRIPE_PRICE_PRO=price_...             # recurring base, Pro ($20/mo)
#   STRIPE_PRICE_SCALE=price_...           # recurring base, Scale ($80/mo)
#   STRIPE_PRICE_OVERAGE=price_...         # metered, per 1,000 emails (optional)
#   STRIPE_PRICE_SEAT=price_...            # recurring, per extra seat
#   STRIPE_PRICE_ADDON_DEDICATED_IP=price_...
#   STRIPE_PRICE_ADDON_SUBTENANT_PACK=price_...
# Where Stripe Checkout returns the user (your dashboard origin). Also used by
# the dashboard to build OAuth redirect URIs, so keep the two in sync.
DASHBOARD_URL=http://localhost:3001

# --- AI template drafting -------------------------------------------------
# Powers the "Ask AI" slash command in the template editor. Unset => a built-in
# deterministic mock writes the draft, so the feature is fully demoable with no
# key. Set the key to use real Claude.
#   ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-opus-4-8

# --- Asset uploads --------------------------------------------------------
# Local dev driver writes uploads under ASSET_STORAGE_DIR and serves them at
# ASSET_PUBLIC_URL (swap for S3 in production via the storage interface).
ASSET_STORAGE_DIR=.assets
ASSET_PUBLIC_URL=http://localhost:4000/assets
UPLOAD_MAX_BYTES=5242880
