# ---------------------------------------------------------------------------
# rootmail — local environment TEMPLATE
# Copy to .env (the seed/verify steps do this for you) and adjust as needed.
#
# ⚠️  THIS FILE IS COMMITTED TO GIT. Keep it placeholders only — never paste
#     real secrets here. Real values go in .env (gitignored) or, for the
#     dashboard, apps/dashboard/.env.local.
# ---------------------------------------------------------------------------

# Docker host ports — override if 5432/6379 are taken on your machine.
POSTGRES_PORT=5432
REDIS_PORT=6379

# Postgres (matches docker-compose.yml). For a hosted DB (e.g. RDS):
#   DATABASE_URL=postgres://<user>:<password>@<endpoint>:5432/<db>?sslmode=require
DATABASE_URL=postgres://rootmail:rootmail@localhost:5432/rootmail

# Redis — queue, idempotency cache, rate limits (matches docker-compose.yml).
# NOTE: ElastiCache (especially serverless) is VPC-only and is NOT reachable
# from a laptop without a bastion/tunnel. Keep this local unless you run inside
# the VPC.
REDIS_URL=redis://localhost:6379

# API server
API_PORT=4000
API_HOST=0.0.0.0
LOG_LEVEL=info

# Public base URL of the API — used in DNS instructions and unsubscribe links
PUBLIC_API_URL=http://localhost:4000

# Shared secret the first-party dashboard uses to call internal API endpoints
# (social-login user upsert). Set the SAME value in apps/dashboard/.env.local.
# Leave unset to disable social login. Generate with: openssl rand -hex 32
# INTERNAL_API_SECRET=

# --- Social login ---------------------------------------------------------
# Pick ONE approach. Both are read by the DASHBOARD — put creds in
# apps/dashboard/.env.local, not here.
#
# A) Direct OAuth (currently wired, no extra SDK):
#      DASHBOARD_URL=http://localhost:3001     # used to build redirect URIs
#      GOOGLE_CLIENT_ID= / GOOGLE_CLIENT_SECRET=
#      GITHUB_CLIENT_ID= / GITHUB_CLIENT_SECRET=
#      APPLE_CLIENT_ID= (Services ID) / APPLE_TEAM_ID= / APPLE_KEY_ID= / APPLE_PRIVATE_KEY= (.p8 PKCS8)
#    Register callback `${DASHBOARD_URL}/oauth/<provider>/callback` per provider.
#    Buttons appear automatically once a provider is configured. (Apple requires an
#    HTTPS redirect URI — use a tunnel in local dev.)
#
# B) Firebase Auth (one console fans out to many providers — NOT yet wired):
#      FIREBASE_PROJECT_ID=
#      FIREBASE_CLIENT_EMAIL=
#      FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Root sending identity
ROOTMAIL_DOMAIN=rootmail.io
DKIM_SELECTOR=rootmail

# --- AWS (SES sending, S3 asset storage) ----------------------------------
# Read by the AWS SDK's default credential chain. Prefer an IAM role in prod;
# use a scoped IAM user's keys locally.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Sub-tenant domain verification:
#   mock = always pass (local dev, no real DNS)
#   live = perform real DNS TXT lookups for ownership + DKIM
DNS_VERIFY_MODE=mock

# Outbound provider:
#   mock     = writes rendered .eml files to MAILDIR (default; no creds needed)
#   ses      = Amazon SES (needs AWS_* above + a verified domain/identity)
#   sendgrid = stub, not implemented
# SES feedback (bounce/complaint/delivery): create an SNS topic, point SES identity
# Feedback notifications at it, and add an HTTPS subscription to
# <PUBLIC_API_URL>/v1/webhooks/ses (raw message delivery OFF). Suppression is
# then automatic. Test-mode sends always use mock, so they never bounce SES.
MAIL_PROVIDER=mock

# Where the mock provider writes rendered .eml files for inspection
MAILDIR=.maildir

# Inbound replies (Layer 2 conversations) via SES. Point the MX of a dedicated
# subdomain at SES inbound (inbound-smtp.<region>.amazonaws.com) and add a receipt
# rule with an SNS action → <PUBLIC_API_URL>/v1/webhooks/ses. Outbound thread sends
# then set Reply-To: reply+<threadId>@<INBOUND_DOMAIN>, which the webhook matches
# back to the thread. Unset → reply capture is off.
# INBOUND_DOMAIN=reply.gateml.io

# --- Billing (Stripe) -----------------------------------------------------
# Leave STRIPE_SECRET_KEY unset for "local" mode: plan changes apply instantly
# (the pre-Stripe self-serve switch) and prices come from the PLANS/ADD_ONS
# defaults baked into packages/core. Set it to switch on real Stripe Checkout.
# Create the products/prices in Stripe (test mode), then paste the price IDs
# here. Any price that's missing falls back to its default constant, so the app
# keeps working even mid-setup.
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...        # from `stripe listen --forward-to localhost:4000/v1/webhooks/stripe`
#   STRIPE_PRICE_PRO=price_...             # recurring base, Pro ($20/mo)
#   STRIPE_PRICE_SCALE=price_...           # recurring base, Scale ($80/mo)
#   STRIPE_PRICE_PRO_YEAR=price_...        # annual Pro ($200/yr — 2 months free)
#   STRIPE_PRICE_SCALE_YEAR=price_...      # annual Scale ($800/yr — 2 months free)
#   STRIPE_PRICE_SEAT=price_...            # recurring, per extra seat ($8/mo)
#   STRIPE_PRICE_ADDON_DEDICATED_IP=price_...   # $30/mo
#   STRIPE_PRICE_ADDON_SUBTENANT_PACK=price_... # $15/mo per pack of 10
#   STRIPE_PRICE_ADDON_AI_CREDITS=price_...     # $5/mo per 100 AI credits
# Overage is metered and volume-discounted per plan (Pro $0.85, Scale $0.70 per
# 1,000 emails). Each must be a RECURRING usage-based (metered) price backed by a
# Billing Meter — give the meter's event_name in STRIPE_METER_OVERAGE_*. Overage
# billing only activates for a plan once BOTH its price and meter are set.
#   STRIPE_PRICE_OVERAGE_PRO=price_...     # recurring metered, $0.85 / unit (=1,000 emails)
#   STRIPE_PRICE_OVERAGE_SCALE=price_...   # recurring metered, $0.70 / unit (=1,000 emails)
#   STRIPE_METER_OVERAGE_PRO=...           # the Pro overage meter's event_name
#   STRIPE_METER_OVERAGE_SCALE=...         # the Scale overage meter's event_name
# Where Stripe Checkout returns the user (your dashboard origin). Also used by
# the dashboard to build OAuth redirect URIs, so keep the two in sync.
DASHBOARD_URL=http://localhost:3001

# --- AI template drafting + assistant -------------------------------------
# Powers "Ask AI" in the template editor and the agentic assistant. Unset => a
# built-in deterministic mock answers, so the feature is fully demoable with no
# key. Set the key to use real Claude.
#   ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-opus-4-8

# --- Asset uploads --------------------------------------------------------
# Local dev driver writes uploads under ASSET_STORAGE_DIR and serves them at
# ASSET_PUBLIC_URL. For S3 (not yet wired): set ASSET_S3_BUCKET + AWS_* above.
# ASSET_S3_BUCKET=
ASSET_STORAGE_DIR=.assets
ASSET_PUBLIC_URL=http://localhost:4000/assets
UPLOAD_MAX_BYTES=5242880

# --- Layer 3 proof bundles ------------------------------------------------
# Ed25519 private key (PKCS8 PEM) used to sign exportable proof bundles. Unset
# uses a stable dev key baked into source (dev-only — set your own in prod).
# Generate:  openssl genpkey -algorithm ed25519
# Provide as a double-quoted multi-line value, or single line with \n escapes.
#   PROOF_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
