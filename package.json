{
  "name": "rootmail",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "rootmail — unified email infrastructure that scales with who's asking.",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v",
    "db:generate": "pnpm --filter @rootmail/db generate",
    "db:migrate": "pnpm --filter @rootmail/db migrate",
    "db:push": "pnpm --filter @rootmail/db push",
    "db:studio": "pnpm --filter @rootmail/db studio",
    "db:seed": "pnpm --filter @rootmail/db seed",
    "create-staff": "pnpm --filter @rootmail/db create-staff",
    "api": "pnpm --filter @rootmail/api dev",
    "worker": "pnpm --filter @rootmail/worker dev",
    "marketing": "pnpm --filter @rootmail/marketing dev",
    "dashboard": "pnpm --filter @rootmail/dashboard dev",
    "admin": "pnpm --filter @rootmail/admin dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msgpackr-extract", "sharp"],
    "overrides": {
      "ioredis": "^5.11.1"
    }
  }
}
